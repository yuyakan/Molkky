    "レビューであなたの感想を聞かせてください。アプリの改善にとても役立ちます。": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Napište nám svůj názor v recenzi. Velmi nám to pomáhá aplikaci zlepšovat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sag uns deine Meinung in einer Bewertung. Das hilft uns sehr, die App zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tell us what you think in a review. It really helps us improve the app."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kerro mielipiteesi arvostelussa. Se auttaa meitä kehittämään sovellusta."
          }
        }
