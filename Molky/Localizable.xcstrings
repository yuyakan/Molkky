    },
    "このチームを保存": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save this team"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tallenna tämä joukkue"
          }
        },
        "cs": {
          "stringUnit": {
