    "このメンバーは登録から削除されます。対戦履歴は残ります。": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento hráč bude odebrán ze seznamu. Historie her zůstane zachována."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Spieler wird aus der Liste entfernt. Spielverlauf bleibt erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This player will be removed from your roster. Past game records will remain."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Mängija eemaldatakse nimekirjast. Varasemad mängud jäävad alles."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä pelaaja poistetaan listalta. Pelihistoria säilyy."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il giocatore verrà rimosso dall'elenco. I risultati passati rimarranno."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gracz zostanie usunięty z listy. Historia gier pozostanie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spelaren tas bort från din lista. Tidigare spelresultat finns kvar."
          }
        }
      }
    },
