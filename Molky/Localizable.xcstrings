    "よく使う編成を保存すると、ゲーム開始時にタップだけで再現できます。": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uložte si často používané sestavy a načtěte je při startu hry jedním klepnutím."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichere häufig genutzte Aufstellungen und übernimm sie beim Spielstart mit einem Tipp."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save your frequent lineups so you can recreate them with one tap when starting a game."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvesta sageli kasutatavad koosseisud, et neid mängu alustamisel ühe puudutusega taastada."
