        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz często używane składy, aby odtworzyć je jednym dotknięciem przy rozpoczęciu gry."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
