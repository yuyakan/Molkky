            "value": "Uložit tento tým"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Team speichern"
          }
        }
      }
    },
    "このチームを削除": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete this team"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Poista tämä joukkue"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Smazat tento tým"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Team löschen"
          }
        }
      }
    },
    "このメンバーは登録から削除されます。対戦履歴は残ります。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This player will be removed from your roster. Past game records will remain."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä pelaaja poistetaan listalta. Pelihistoria säilyy."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento hráč bude odebrán ze seznamu. Historie her zůstane zachována."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Spieler wird aus der Liste entfernt. Spielverlauf bleibt erhalten."
          }
        }
      }
    },
    "このメンバーを削除": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete this player"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Poista tämä pelaaja"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Smazat tohoto hráče"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diesen Spieler löschen"
          }
        }
      }
    },
    "これらの値は新規ゲーム作成時の初期値として使用されます。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These values will be used as defaults when starting a new game."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Näitä arvoja käytetään oletuksina uutta peliä aloitettaessa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tyto hodnoty se použijí jako výchozí při zahájení nové hry."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Werte werden als Standard für neue Spiele verwendet."
          }
        }
      }
    },
    "その人/チームが脱落": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That player/team is eliminated"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kyseinen pelaaja tai joukkue putoaa"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hráč nebo tým je vyřazen"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spieler oder Team scheidet aus"
          }
        }
      }
    },
    "よく使う編成を保存すると、ゲーム開始時にタップだけで再現できます。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save your frequent lineups so you can recreate them with one tap when starting a game."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tallenna usein käyttämäsi kokoonpanot, niin voit ottaa ne käyttöön yhdellä napautuksella."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uložte si často používané sestavy a načtěte je při startu hry jedním klepnutím."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichere häufig genutzte Aufstellungen und übernimm sie beim Spielstart mit einem Tipp."
          }
        }
      }
    },
