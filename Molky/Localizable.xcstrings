    "ここまでのスコアは記録されません。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scores so far will not be saved."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tähän asti saatuja pisteitä ei tallenneta."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dosavadní skóre nebude uloženo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bisheriger Punktestand wird nicht gespeichert."
          }
        }
      }
    },
