        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Registreeri mängijad või alusta uut mängu, et oma tulemusi jälgida."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tallenna pelaajia tai aloita uusi peli tallentaaksesi tuloksia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra i giocatori o inizia una nuova partita per tracciare i tuoi risultati."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zarejestruj graczy lub rozpocznij nową grę, aby śledzić wyniki."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrera spelare eller starta ett nytt spel för att spåra dina resultat."
          }
        }
      }
    },
