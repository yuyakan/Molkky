    "レビューであなたの感想を聞かせてください。アプリの改善にとても役立ちます。": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Napište nám svůj názor v recenzi. Velmi nám to pomáhá aplikaci zlepšovat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sag uns deine Meinung in einer Bewertung. Das hilft uns sehr, die App zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tell us what you think in a review. It really helps us improve the app."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Anna arvustuses teada, mida arvad. See aitab meil rakendust paremaks muuta."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kerro mielipiteesi arvostelussa. Se auttaa meitä kehittämään sovellusta."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dicci cosa ne pensi in una recensione. Ci aiuta davvero a migliorare l'app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Podziel się opinią w recenzji. To naprawdę pomaga nam ulepszać aplikację."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Berätta vad du tycker i en recension. Det hjälper oss att förbättra appen."
          }
        }
      }
    },
