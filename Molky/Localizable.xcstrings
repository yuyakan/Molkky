    "チームの登録が削除されます。所属メンバーは削除されません。対戦履歴は残ります。": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento tým bude odstraněn. Hráči a historie her zůstanou zachováni."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Team wird entfernt. Spieler und Spielverlauf bleiben erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This team will be removed. Member registrations and past game records will remain."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiim eemaldatakse. Liikmed ja varasemad mängud jäävad alles."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä joukkue poistetaan. Pelaajat ja pelihistoria säilyvät."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La squadra verrà rimossa. I membri e i risultati passati rimarranno."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Drużyna zostanie usunięta. Członkowie i historia gier pozostaną."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Laget tas bort. Medlemmar och tidigare spelresultat finns kvar."
          }
        }
      }
    },
